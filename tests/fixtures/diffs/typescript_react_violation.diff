+import React, { useState, useEffect } from 'react';
+
+// Violation: business logic mixed into component,
+// no custom hook extraction, direct fetch in useEffect
+export const UserProfile = ({ userId }: { userId: string }) => {
+  const [user, setUser] = useState<any>(null);
+  const [orders, setOrders] = useState<any[]>([]);
+  const [loading, setLoading] = useState(true);
+
+  useEffect(() => {
+    fetch(`/api/users/${userId}`)
+      .then(res => res.json())
+      .then(data => {
+        setUser(data);
+        // Violation: nested fetch inside useEffect
+        fetch(`/api/users/${userId}/orders`)
+          .then(res => res.json())
+          .then(orderData => {
+            setOrders(orderData);
+            setLoading(false);
+          });
+      });
+  }, [userId]);
+
+  // Violation: complex calculation inline in render
+  const totalSpent = orders.reduce((sum, o) => sum + o.total, 0);
+  const isVip = totalSpent > 1000;
+
+  if (loading) return <div>Loading...</div>;
+
+  return (
+    <div>
+      <h1>{user?.name}</h1>
+      <p>Email: {user?.email}</p>
+      <p>Total Spent: ${totalSpent}</p>
+      {isVip && <span className="badge">VIP Customer</span>}
+      <ul>
+        {orders.map((o, i) => (
+          <li key={i}>{o.name}: ${o.total}</li>
+        ))}
+      </ul>
+    </div>
+  );
+};
