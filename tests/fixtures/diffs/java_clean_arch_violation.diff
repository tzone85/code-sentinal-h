+package com.example.domain;
+
+import com.example.infrastructure.UserRepository;
+import com.example.adapter.http.UserDto;
+import javax.persistence.EntityManager;
+
+/**
+ * Domain service that violates Clean Architecture by
+ * importing from infrastructure and adapter layers.
+ */
+public class UserService {
+    private final UserRepository repository;
+    private final EntityManager em;
+
+    public UserService(UserRepository repository, EntityManager em) {
+        this.repository = repository;
+        this.em = em;
+    }
+
+    public UserDto findUser(Long id) {
+        var user = repository.findById(id);
+        var dto = new UserDto(user.getName(), user.getEmail());
+        return dto;
+    }
+}
